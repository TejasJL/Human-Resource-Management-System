{
  "info": {
    "name": "MERN HRMS API",
    "description": "Postman collection for the Human Resource Management System (HRMS) API covering Authentication, Employees, Attendance, Leaves, Holidays, and Payroll.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Employee / Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hrms.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Employees (Admin)",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"Employee\",\n  \"designation\": \"Developer\",\n  \"monthlySalary\": 50000,\n  \"phoneNumber\": \"9876543210\",\n  \"dateOfJoining\": \"2026-07-01\",\n  \"employmentType\": \"<EMPLOYMENT_TYPE_ID>\",\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthlySalary\": 60000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Punch In",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/punch-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "punch-in"]
            }
          }
        },
        {
          "name": "Punch Out",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/punch-out",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "punch-out"]
            }
          }
        },
        {
          "name": "Get My Attendance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/my?month=07&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "my"],
              "query": [
                { "key": "month", "value": "07" },
                { "key": "year", "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "Get All Attendance (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/attendance?month=2026-07",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance"],
              "query": [
                { "key": "month", "value": "2026-07" }
              ]
            }
          }
        },
        {
          "name": "Get Attendance Report (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/report?month=2026-07",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "report"],
              "query": [
                { "key": "month", "value": "2026-07" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leaves",
      "item": [
        {
          "name": "Apply Leave",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"Paid Leave\",\n  \"fromDate\": \"2026-08-15\",\n  \"toDate\": \"2026-08-15\",\n  \"isHalfDay\": false,\n  \"reason\": \"Personal work\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leaves/apply",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves", "apply"]
            }
          }
        },
        {
          "name": "Get My Leave Balances",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/leaves/balances",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves", "balances"]
            }
          }
        },
        {
          "name": "Get My Leaves",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/leaves/my",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves", "my"]
            }
          }
        },
        {
          "name": "Get All Leaves (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/leaves",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves"]
            }
          }
        },
        {
          "name": "Update Leave Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Approved\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leaves/{{leaveId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves", "{{leaveId}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Employment Types (Admin)",
      "item": [
        {
          "name": "Get Employment Types",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employment-types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employment-types"]
            }
          }
        },
        {
          "name": "Create Employment Type",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Full Time\",\n  \"leavePolicy\": {\n    \"casual\": 12,\n    \"sick\": 12,\n    \"paid\": 18,\n    \"unpaid\": 9999\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employment-types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employment-types"]
            }
          }
        }
      ]
    },
